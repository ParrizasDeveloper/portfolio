---
import GitHubIntro from "../icons/GitHubIntro.astro";
import LinkedIn from "../icons/LinkedIn.astro";
import Plane from "../icons/Plane.astro";
import BounceProjects from "./BounceProjects.astro";
---

<section id="home" class="flex justify-center px-8 h-screen relative">
    <div
        class="flex flex-col justify-center items-center w-full lg:max-w-4xl md:max-w-3xl text-center relative"
    >
        <h1 class="text-gray-100 font-extrabold text-4xl sm:text-7xl mb-2">
            Miguel Angel Párrizas
        </h1>
        <h2 class="mb-10 font-bold text-2xl sm:text-4xl text-purple-300">
            Frontend Developer · React & Next.js
        </h2>
        <p class="text-gray-300 text-xl sm:text-2xl max-w-3xl">
            Desarrollo
            interfaces web modernas
            centradas en
            rendimiento y experiencia
            de usuario usando
            
                tecnologías modernas del ecosistema JavaScript.
            </span>
        </p>
        <p id="main-stack" class="text-gray-300 text-xl sm:text-2xl max-w-3xl mt-4">
            <span>React</span>
            · <span>Next.js</span>
            · <span>TypeScript</span>
            · <span>Tailwind CSS</span>
            · <span>GSAP</span>
        </p>
        <div class="links flex flex-wrap justify-center py-8 gap-4">
            <a
                href="mailto:maparrizasd@gmail.com"
                target="_blank"
                class="flex items-center gap-2 px-3 py-1 rounded-full border border-gray-500 hover:scale-105 transition-all"
            >
                <Plane className="w-5 h-full" />
                <span class="font-semibold">Contáctame</span>
            </a>
            <a
                href="https://www.linkedin.com/in/parrizas"
                target="_blank"
                class="flex items-center gap-2 px-3 py-1 rounded-full border border-gray-500 hover:scale-105 transition-all"
            >
                <LinkedIn className="w-5 h-full" />
                <span class="font-semibold">LinkedIn</span>
            </a>
            <a
                href="https://github.com/ParrizasDeveloper"
                target="_blank"
                class="flex items-center gap-2 px-3 py-1 rounded-full border border-gray-500 hover:scale-105 transition-all"
            >
                <GitHubIntro className="w-5 h-full" />
                <span class="font-semibold">GitHub</span>
            </a>
        </div>
        <BounceProjects />
    </div>
</section>
<style>
    div.links a {
        background-color: rgb(34 34 51);
    }
    #main-stack span:nth-of-type(odd) {
        color: #fdba74;
    }
    #main-stack span:nth-of-type(even) {
        color: #c4b5fd;
    }
</style>
